# KataGo backend URL
# Set this to the address of your KataGo backend server.
# - For the bundled Node.js server (server.js): http://localhost:8000
# - For same-origin proxy mode (Docker Compose frontend): /api
# - For a remote or Docker-based FastAPI backend: https://your-server.example.com
VITE_KATAGO_BACKEND_URL=http://localhost:8000

# Vite dev server proxy target used when VITE_KATAGO_BACKEND_URL is /api
VITE_KATAGO_PROXY_TARGET=http://localhost:8000
